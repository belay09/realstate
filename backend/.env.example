APP_NAME=Belay Properties API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
DATABASE_URL=postgresql+psycopg://belay:belay_dev_password@localhost:5432/belay_properties
JWT_SECRET_KEY=change-this-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DEFAULT_CURRENCY=ETB
QUOTE_EXPIRY_DAYS=7
MAX_UPLOAD_SIZE_MB=5
ENABLE_OCR_IMPORT=false
