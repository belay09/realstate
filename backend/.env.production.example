APP_NAME=Belay Properties API
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
# Comma-separated production origins (no localhost in production)
BACKEND_CORS_ORIGINS=https://realtor.example.com,https://www.realtor.example.com
DATABASE_URL=postgresql+psycopg://belay:CHANGE_ME@db:5432/belay_properties
JWT_SECRET_KEY=generate-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DEFAULT_CURRENCY=ETB
QUOTE_EXPIRY_DAYS=7
MAX_UPLOAD_SIZE_MB=150
ENABLE_OCR_IMPORT=false
