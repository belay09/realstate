# Copy to .env on the EC2 server (same folder as docker-compose.prod.yml)
POSTGRES_DB=belay_properties
POSTGRES_USER=belay
POSTGRES_PASSWORD=generate-a-strong-password

SITE_DOMAIN=realtor.belay-sirak.com
API_DOMAIN=api.realtor.belay-sirak.com

# Passed as build-arg to the frontend image
VITE_API_BASE_URL=https://api.realtor.belay-sirak.com/api/v1
