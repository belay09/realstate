# Base URL for FastAPI (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Optional: WhatsApp in international format without + (e.g. 251911234567 for Ethiopia)
# Optional override; defaults to Belay contact 0962750710
# VITE_WHATSAPP_E164=251962750710

# Admin media uploads use the API (signed Cloudinary). Configure in backend/.env:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
